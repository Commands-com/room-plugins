{
  "id": "postgres_query_optimizer",
  "name": "Postgres Query Optimizer",
  "version": "1.0.0",
  "orchestratorType": "postgres_query_optimizer",
  "description": "Empirical SQL performance tuning: rewrite queries, propose indexes, and verify speedup with EXPLAIN ANALYZE",
  "supportsQuorum": true,
  "roles": {
    "required": ["explorer", "builder", "auditor"],
    "optional": [],
    "forbidden": ["implementer", "reviewer", "worker"],
    "minCount": {
      "explorer": 1,
      "builder": 1,
      "auditor": 1
    }
  },
  "limits": {
    "maxCycles": { "default": 4, "min": 1, "max": 10 },
    "maxTurns": { "default": 60, "min": 4, "max": 500 },
    "maxDurationMs": { "default": 3600000, "min": 60000, "max": 14400000 },
    "maxFailures": { "default": 5, "min": 1, "max": 20 },
    "agentTimeoutMs": { "default": 1800000, "min": 10000, "max": 3600000 },
    "pluginHookTimeoutMs": { "default": 360000, "min": 5000, "max": 600000 },
    "llmTimeoutMs": { "default": 60000, "min": 10000, "max": 300000 },
    "turnFloorRole": "explorer",
    "turnFloorFormula": "1 + N"
  },
  "endpointConstraints": {
    "requiresLocalParticipant": true,
    "perRole": {}
  },
  "dashboard": {
    "panels": [
      {
        "type": "text",
        "key": "preflightStatus",
        "label": "Setup Progress"
      },
      {
        "type": "phase",
        "key": "currentPhase",
        "label": "Phase",
        "phases": [
          "preflight",
          "baseline",
          "analysis",
          "codegen",
          "static_audit",
          "frontier_refine",
          "complete"
        ],
        "phaseLabels": {
          "preflight": "Preflight",
          "baseline": "Baseline",
          "analysis": "Analysis",
          "codegen": "Codegen",
          "static_audit": "Static Audit",
          "frontier_refine": "Refine",
          "complete": "Complete"
        }
      },
      {
        "type": "table",
        "key": "baselines",
        "label": "Baseline",
        "columns": [
          { "key": "metric", "label": "Metric", "width": 160 },
          { "key": "value", "label": "Value", "width": 200 }
        ]
      },
      {
        "type": "counter-group",
        "key": "candidateSummary",
        "label": "Strategies",
        "layout": "row",
        "counters": [
          { "key": "proposed", "label": "Proposed", "color": "gray" },
          { "key": "promoted", "label": "Promoted", "color": "blue" },
          { "key": "benchmarked", "label": "Benchmarked", "color": "green" },
          { "key": "frontier", "label": "Frontier", "color": "orange" },
          { "key": "rejected", "label": "Rejected", "color": "red" }
        ]
      },
      {
        "type": "progress",
        "key": "cycleProgress",
        "label": "Cycle Progress",
        "format": "{value} / {max}"
      },
      {
        "type": "progress",
        "key": "bestImprovementPct",
        "label": "Best Speedup",
        "format": "{value}%"
      },
      {
        "type": "code-blocks",
        "key": "solutions",
        "label": "Solutions",
        "language": "sql"
      },
      {
        "type": "table",
        "key": "frontier",
        "label": "Frontier",
        "columns": [
          { "key": "cycle", "label": "Cycle", "width": 50 },
          { "key": "strategyType", "label": "Type", "width": 100 },
          { "key": "proposalId", "label": "Proposal", "width": 180 },
          { "key": "medianMs", "label": "Time (ms)", "width": 100 },
          { "key": "speedupPct", "label": "Speedup %", "width": 100 },
          { "key": "indexSizeMb", "label": "Index Size", "width": 100 },
          { "key": "riskScore", "label": "Risk", "width": 60 },
          { "key": "status", "label": "Status", "width": 90 },
          { "key": "owner", "label": "Builder", "width": 120 }
        ],
        "sortable": true
      },
      {
        "type": "table",
        "key": "candidates",
        "label": "All Attempts",
        "columns": [
          { "key": "cycle", "label": "Cycle", "width": 50 },
          { "key": "strategyType", "label": "Type", "width": 100 },
          { "key": "proposalId", "label": "Proposal", "width": 180 },
          { "key": "medianMs", "label": "Time (ms)", "width": 100 },
          { "key": "speedupPct", "label": "Speedup %", "width": 100 },
          { "key": "status", "label": "Status", "width": 90 },
          { "key": "riskScore", "label": "Risk", "width": 60 },
          { "key": "owner", "label": "Builder", "width": 120 },
          { "key": "notes", "label": "Notes", "width": 300 }
        ],
        "sortable": true
      }
    ]
  },
  "objective": {
    "required": false,
    "placeholder": "Optional: add constraints or priorities (e.g. \"latency matters more than index size\", \"no new indexes on orders\", \"focus on the users \u2194 audit_log join\")"
  },
  "display": {
    "typeLabel": "Postgres Query Optimizer",
    "typeTag": "SQL",
    "cycleNoun": "Cycle",
    "reportTitle": "Postgres Query Optimization Report",
    "activityMessages": {
      "idle": "Waiting...",
      "discovery": "Analyzing slow queries and schema",
      "fanOut": "Running EXPLAIN ANALYZE on candidates",
      "singleTurn": "Worker optimizing query...",
      "synthesis": "Ranking optimization frontier",
      "planning": "Choosing next tuning strategy"
    },
    "defaultRoster": [
      { "role": "explorer", "displayName": "Schema Analyst" },
      { "role": "builder", "displayName": "Query Architect" },
      { "role": "auditor", "displayName": "DBA Auditor" }
    ],
    "defaultAddRole": "explorer"
  },
  "report": {
    "summaryMetrics": ["bestImprovementPct", "candidateSummary"],
    "table": {
      "metricKey": "candidates",
      "columns": [
        { "key": "cycle", "label": "Cycle", "width": 50 },
        { "key": "strategyType", "label": "Type", "width": 120 },
        { "key": "medianMs", "label": "Execution (ms)", "width": 110 },
        { "key": "speedupPct", "label": "Speedup %", "width": 100 },
        { "key": "status", "label": "Status", "width": 90 },
        { "key": "owner", "label": "Builder", "width": 120 },
        { "key": "notes", "label": "Notes", "width": 300 }
      ]
    },
    "codeBlocks": [
      { "metricKey": "solutions", "label": "All Solutions", "language": "sql" },
      { "metricKey": "winnerIndexes", "label": "Proposed Indexes", "language": "sql" }
    ]
  },
  "configSchema": {
    "plannedCandidatesPerCycle": { "type": "integer", "min": 1, "max": 10, "default": 4 },
    "promoteTopK": { "type": "integer", "min": 1, "max": 5, "default": 2 },
    "maxRetestCandidates": { "type": "integer", "min": 1, "max": 3, "default": 1 },
    "maxRiskScore": { "type": "integer", "min": 0, "max": 10, "default": 7 },
    "targetImprovementPct": { "type": "number", "min": 0, "max": 1000, "default": 20 },
    "warmupRuns": { "type": "integer", "min": 1, "max": 20, "default": 3 },
    "benchmarkTrials": { "type": "integer", "min": 3, "max": 50, "default": 10 },
    "plateauCycles": { "type": "integer", "min": 1, "max": 5, "default": 2 },
    "scaleFactor": { "type": "integer", "min": 1000, "max": 2000000, "default": 100000 }
  },
  "roomConfigSchema": {
    "demoMode": {
      "type": "callout",
      "label": "Demo Mode",
      "default": false,
      "description": "Use bundled e-commerce schema, data, and slow query. No database or Docker needed for config — Docker still required at runtime."
    },
    "dbUrl": {
      "type": "string",
      "label": "Postgres URL",
      "fullWidth": true,
      "required": false,
      "placeholder": "postgres://user:pass@localhost:5432/db",
      "description": "Postgres connection string for schema introspection and optional data sampling.",
      "visibleWhen": { "demoMode": false }
    },
    "slowQuery": {
      "type": "string",
      "label": "Target Query",
      "fullWidth": true,
      "required": false,
      "multiline": true,
      "rows": 6,
      "placeholder": "SELECT * FROM large_table WHERE...",
      "description": "SQL to optimize. Must be a read-only SELECT or WITH...SELECT with concrete values.",
      "visibleWhen": { "demoMode": false }
    },
    "showAdvanced": {
      "type": "boolean",
      "label": "Advanced Options",
      "default": false,
      "visibleWhen": { "demoMode": false }
    },
    "_schemaSection": {
      "type": "section",
      "label": "Schema & Data",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "schemaSource": {
      "type": "enum",
      "label": "Schema Source",
      "options": ["introspect", "dump", "migrations"],
      "default": "introspect",
      "description": "How to load the database schema into the Docker harness.",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "schemaPath": {
      "type": "string",
      "label": "Schema Path",
      "required": false,
      "description": "Path to pg_dump schema or migrations directory. Required when schemaSource is dump or migrations.",
      "visibleWhen": { "demoMode": false, "showAdvanced": true, "schemaSource": ["dump", "migrations"] }
    },
    "seedDataPath": {
      "type": "string",
      "label": "Seed Data Path",
      "description": "SQL script or pg_dump data-only file to populate the harness (Tier 1).",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "seedFromSource": {
      "type": "boolean",
      "label": "Sample from Source",
      "default": false,
      "description": "Sample real rows from dbUrl instead of synthetic data (Tier 2).",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "schemaFilter": {
      "type": "string_array",
      "label": "Include Tables",
      "maxItems": 20,
      "default": [],
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "_harnessSection": {
      "type": "section",
      "label": "Harness Settings",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "postgresVersion": {
      "type": "enum",
      "label": "Postgres Version",
      "options": ["14", "15", "16", "17"],
      "default": "16",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "scaleFactor": {
      "type": "string",
      "label": "Scale Factor",
      "default": "100000",
      "description": "Target row count for data sampling and synthetic generation (1000–1000000). Parsed as integer in plugin code.",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "containerMemory": {
      "type": "enum",
      "label": "Container Memory",
      "options": ["512m", "1g", "2g", "4g"],
      "default": "1g",
      "description": "Memory limit for the Docker harness container. Increase for large tables.",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    },
    "outputDir": {
      "type": "directory",
      "label": "Output Directory",
      "default": ".commands/postgres-tuner",
      "visibleWhen": { "showAdvanced": true }
    },
    "productionStats": {
      "type": "string",
      "label": "Production Stats JSON",
      "fullWidth": true,
      "required": false,
      "multiline": true,
      "rows": 4,
      "placeholder": "{ \"pg_stat_user_tables\": [...], \"pg_stat_statements\": [...] }",
      "description": "Optional JSON blob of pg_stat_user_tables / pg_stat_statements data for telemetry-assisted auditing.",
      "visibleWhen": { "demoMode": false, "showAdvanced": true }
    }
  },
  "setup": {
    "compatibilityGate": true,
    "compatibilityTitle": "Postgres Optimizer Preflight",
    "compatibilityDescription": "Verify Docker availability and configuration before starting. Docker is required to spin up an isolated Postgres instance for benchmarking.",
    "checkLabel": "Verify Setup",
    "fixLabel": "Setup Tuner Workspace",
    "allowMakeCompatible": true
  }
}
