{
  "id": "redshift_query_optimizer",
  "name": "Redshift Query Optimizer",
  "version": "1.0.0",
  "orchestratorType": "redshift_query_optimizer",
  "description": "Empirical SQL performance tuning for Amazon Redshift: rewrite queries, benchmark on-cluster, and recommend sort/dist key changes",
  "supportsQuorum": true,
  "roles": {
    "required": ["explorer", "builder", "auditor"],
    "optional": [],
    "forbidden": ["implementer", "reviewer", "worker"],
    "minCount": {
      "explorer": 1,
      "builder": 1,
      "auditor": 1
    }
  },
  "limits": {
    "maxCycles": { "default": 4, "min": 1, "max": 10 },
    "maxTurns": { "default": 60, "min": 4, "max": 500 },
    "maxDurationMs": { "default": 3600000, "min": 60000, "max": 14400000 },
    "maxFailures": { "default": 5, "min": 1, "max": 20 },
    "agentTimeoutMs": { "default": 1800000, "min": 10000, "max": 3600000 },
    "pluginHookTimeoutMs": { "default": 120000, "min": 5000, "max": 600000 },
    "llmTimeoutMs": { "default": 60000, "min": 10000, "max": 300000 },
    "turnFloorRole": "explorer",
    "turnFloorFormula": "1 + N"
  },
  "endpointConstraints": {
    "requiresLocalParticipant": true,
    "perRole": {}
  },
  "dashboard": {
    "panels": [
      {
        "type": "text",
        "key": "preflightStatus",
        "label": "Setup Progress"
      },
      {
        "type": "phase",
        "key": "currentPhase",
        "label": "Phase",
        "phases": [
          "preflight",
          "baseline",
          "analysis",
          "codegen",
          "static_audit",
          "frontier_refine",
          "synthesis",
          "complete"
        ],
        "phaseLabels": {
          "preflight": "Preflight",
          "baseline": "Baseline",
          "analysis": "Analysis",
          "codegen": "Codegen",
          "static_audit": "Static Audit",
          "frontier_refine": "Refine",
          "synthesis": "Synthesis",
          "complete": "Complete"
        }
      },
      {
        "type": "table",
        "key": "baselines",
        "label": "Baseline",
        "columns": [
          { "key": "metric", "label": "Metric", "width": 160 },
          { "key": "value", "label": "Value", "width": 200 }
        ]
      },
      {
        "type": "counter-group",
        "key": "candidateSummary",
        "label": "Strategies",
        "layout": "row",
        "counters": [
          { "key": "proposed", "label": "Proposed", "color": "gray" },
          { "key": "promoted", "label": "Promoted", "color": "blue" },
          { "key": "benchmarked", "label": "Benchmarked", "color": "green" },
          { "key": "frontier", "label": "Frontier", "color": "orange" },
          { "key": "rejected", "label": "Rejected", "color": "red" }
        ]
      },
      {
        "type": "progress",
        "key": "cycleProgress",
        "label": "Cycle Progress",
        "format": "{value} / {max}"
      },
      {
        "type": "progress",
        "key": "bestImprovementPct",
        "label": "Best Speedup",
        "format": "{value}%"
      },
      {
        "type": "code-blocks",
        "key": "solutions",
        "label": "Solutions",
        "language": "sql"
      },
      {
        "type": "code-blocks",
        "key": "advisoryRecommendations",
        "label": "Table Design Recommendations",
        "language": "sql"
      },
      {
        "type": "code-blocks",
        "key": "recommendedPlan",
        "label": "Recommended Deployment Plan",
        "language": "sql"
      },
      {
        "type": "table",
        "key": "frontier",
        "label": "Frontier",
        "columns": [
          { "key": "cycle", "label": "Cycle", "width": 50 },
          { "key": "strategyType", "label": "Type", "width": 100 },
          { "key": "proposalId", "label": "Proposal", "width": 180 },
          { "key": "medianMs", "label": "Time (ms)", "width": 100 },
          { "key": "speedupPct", "label": "Speedup %", "width": 100 },
          { "key": "riskScore", "label": "Risk", "width": 60 },
          { "key": "status", "label": "Status", "width": 90 },
          { "key": "owner", "label": "Builder", "width": 120 }
        ],
        "sortable": true
      },
      {
        "type": "table",
        "key": "candidates",
        "label": "All Attempts",
        "columns": [
          { "key": "cycle", "label": "Cycle", "width": 50 },
          { "key": "strategyType", "label": "Type", "width": 100 },
          { "key": "proposalId", "label": "Proposal", "width": 180 },
          { "key": "medianMs", "label": "Time (ms)", "width": 100 },
          { "key": "speedupPct", "label": "Speedup %", "width": 100 },
          { "key": "status", "label": "Status", "width": 90 },
          { "key": "riskScore", "label": "Risk", "width": 60 },
          { "key": "owner", "label": "Builder", "width": 120 },
          { "key": "notes", "label": "Notes", "width": 300 }
        ],
        "sortable": true
      }
    ]
  },
  "objective": {
    "required": false,
    "placeholder": "Optional: add constraints or priorities (e.g. \"minimize redistribution steps\", \"avoid table rebuilds\", \"focus on the orders \u2194 line_items join\")"
  },
  "display": {
    "typeLabel": "Redshift Query Optimizer",
    "typeTag": "SQL",
    "cycleNoun": "Cycle",
    "reportTitle": "Redshift Query Optimization Report",
    "activityMessages": {
      "idle": "Waiting...",
      "discovery": "Analyzing query plan and table metadata",
      "fanOut": "Benchmarking rewrites on cluster",
      "singleTurn": "Worker optimizing query...",
      "synthesis": "Agents voting on best deployment plan",
      "planning": "Choosing next tuning strategy"
    },
    "defaultRoster": [
      { "role": "explorer", "displayName": "Schema Analyst" },
      { "role": "builder", "displayName": "Query Architect" },
      { "role": "auditor", "displayName": "DBA Auditor" }
    ],
    "defaultAddRole": "explorer"
  },
  "report": {
    "summaryMetrics": ["bestImprovementPct", "candidateSummary"],
    "table": {
      "metricKey": "candidates",
      "columns": [
        { "key": "cycle", "label": "Cycle", "width": 50 },
        { "key": "strategyType", "label": "Type", "width": 120 },
        { "key": "medianMs", "label": "Execution (ms)", "width": 110 },
        { "key": "speedupPct", "label": "Speedup %", "width": 100 },
        { "key": "status", "label": "Status", "width": 90 },
        { "key": "owner", "label": "Builder", "width": 120 },
        { "key": "notes", "label": "Notes", "width": 300 }
      ]
    },
    "codeBlocks": [
      { "metricKey": "recommendedPlan", "label": "Recommended Deployment Plan", "language": "sql" },
      { "metricKey": "solutions", "label": "All Solutions", "language": "sql" },
      { "metricKey": "advisoryRecommendations", "label": "Table Design Recommendations", "language": "sql" }
    ]
  },
  "configSchema": {
    "plannedCandidatesPerCycle": { "type": "integer", "min": 1, "max": 10, "default": 4 },
    "promoteTopK": { "type": "integer", "min": 1, "max": 5, "default": 2 },
    "maxRetestCandidates": { "type": "integer", "min": 1, "max": 3, "default": 2 },
    "maxRiskScore": { "type": "integer", "min": 0, "max": 10, "default": 7 },
    "targetImprovementPct": { "type": "number", "min": 0, "max": 1000, "default": 20 },
    "warmupRuns": { "type": "integer", "min": 1, "max": 20, "default": 2 },
    "benchmarkTrials": { "type": "integer", "min": 3, "max": 50, "default": 5 },
    "plateauCycles": { "type": "integer", "min": 1, "max": 5, "default": 2 }
  },
  "roomConfigSchema": {
    "dbUrl": {
      "type": "string",
      "label": "Redshift URL",
      "required": true,
      "placeholder": "postgres://user:pass@cluster.region.redshift.amazonaws.com:5439/db",
      "description": "Redshift connection string. Uses the Postgres wire protocol."
    },
    "slowQuery": {
      "type": "string",
      "label": "Target Query",
      "required": true,
      "multiline": true,
      "rows": 8,
      "placeholder": "SELECT * FROM large_table WHERE...",
      "description": "SQL to optimize. Must be a read-only SELECT or WITH...SELECT with concrete values."
    },
    "schemaFilter": {
      "type": "string_array",
      "label": "Include Tables",
      "maxItems": 20,
      "default": [],
      "description": "Limit schema analysis to these tables. Leave empty to analyze all tables referenced by the query."
    },
    "outputDir": {
      "type": "directory",
      "label": "Output Directory",
      "default": ".commands/redshift-tuner"
    }
  },
  "setup": {
    "compatibilityGate": true,
    "compatibilityTitle": "Redshift Optimizer Preflight",
    "compatibilityDescription": "Verify Redshift cluster connectivity and query validity before starting.",
    "checkLabel": "Verify Connection",
    "fixLabel": "Setup Tuner Workspace",
    "allowMakeCompatible": true
  }
}
