{
  "id": "ui_ux_testing",
  "name": "UI/UX Testing",
  "version": "2.0.0",
  "orchestratorType": "ui_ux_testing",
  "description": "Deterministic Electron/Web UI workflow testing with fix-and-retest cycles",
  "supportsQuorum": true,
  "roles": {
    "required": [
      "worker"
    ],
    "optional": [],
    "forbidden": [
      "implementer",
      "reviewer"
    ],
    "minCount": {
      "worker": 1
    }
  },
  "limits": {
    "maxCycles": {
      "default": 3,
      "min": 1,
      "max": 20
    },
    "maxTurns": {
      "default": 120,
      "min": 3,
      "max": 2000
    },
    "maxDurationMs": {
      "default": 14400000,
      "max": 43200000
    },
    "maxFailures": {
      "default": 6
    },
    "agentTimeoutMs": {
      "default": 1800000,
      "max": 3600000
    },
    "pluginHookTimeoutMs": {
      "default": 120000,
      "max": 600000
    },
    "llmTimeoutMs": {
      "default": 120000,
      "max": 600000
    },
    "turnFloorRole": "worker",
    "turnFloorFormula": "2 + N"
  },
  "endpointConstraints": {
    "requiresLocalParticipant": true,
    "perRole": {}
  },
  "handoff": {
    "inputs": [
      {
        "contract": "spec_bundle.v1",
        "required": false,
        "multiple": false
      },
      {
        "contract": "implementation_bundle.v1",
        "required": false,
        "multiple": false
      },
      {
        "contract": "review_findings.v1",
        "required": false,
        "multiple": false
      }
    ],
    "outputs": [
      {
        "contract": "test_results.v1",
        "default": true
      },
      {
        "contract": "spec_bundle.v1"
      },
      {
        "contract": "implementation_bundle.v1"
      },
      {
        "contract": "review_findings.v1"
      }
    ],
    "defaultApprovalMode": "auto"
  },
  "display": {
    "typeLabel": "UI/UX Testing",
    "typeTag": "UXT",
    "cycleNoun": "Cycle",
    "reportTitle": "UI/UX Testing Report",
    "activityMessages": {
      "idle": "Waiting...",
      "discovery": "Workers exploring the codebase",
      "writing": "Worker writing test",
      "fanOut": "Workers running test scenarios",
      "singleTurn": "Worker running scenario",
      "synthesis": "Evaluating test results",
      "planning": "Generating UI test scenarios"
    },
    "defaultRoster": [
      {
        "role": "worker",
        "displayName": "Tester 1"
      },
      {
        "role": "worker",
        "displayName": "Tester 2"
      }
    ],
    "defaultAddRole": "worker"
  },
  "dashboard": {
    "panels": [
      {
        "type": "phase",
        "key": "currentPhase",
        "label": "Phase",
        "phases": [
          "discovery",
          "scenario_planning",
          "test_writing",
          "test_execution",
          "fix_retry",
          "evaluation",
          "complete"
        ],
        "phaseLabels": {
          "discovery": "Discovery",
          "scenario_planning": "Scenario Planning",
          "test_writing": "Test Writing",
          "test_execution": "Test Execution",
          "fix_retry": "Fix & Retry",
          "evaluation": "Evaluation",
          "complete": "Complete"
        }
      },
      {
        "type": "counter-group",
        "key": "taskSummary",
        "label": "Scenarios",
        "layout": "row",
        "counters": [
          {
            "key": "pending",
            "label": "Pending",
            "color": "gray"
          },
          {
            "key": "inProgress",
            "label": "Active",
            "color": "blue"
          },
          {
            "key": "done",
            "label": "Done",
            "color": "green"
          },
          {
            "key": "blocked",
            "label": "Blocked",
            "color": "red"
          }
        ]
      },
      {
        "type": "progress",
        "key": "taskProgress",
        "label": "Progress",
        "format": "{value} / {max}"
      },
      {
        "type": "progress",
        "key": "passRate",
        "label": "Pass Rate",
        "format": "{value}%"
      },
      {
        "type": "table",
        "key": "taskBoard",
        "label": "Scenarios",
        "columns": [
          {
            "key": "taskNum",
            "label": "#",
            "width": 30
          },
          {
            "key": "title",
            "label": "Scenario"
          },
          {
            "key": "assignedTo",
            "label": "Worker"
          },
          {
            "key": "status",
            "label": "Status",
            "width": 90
          },
          {
            "key": "result",
            "label": "Result",
            "width": 80
          },
          {
            "key": "retries",
            "label": "Retries",
            "width": 60
          }
        ],
        "sortable": true,
        "filterable": [
          "status",
          "assignedTo"
        ]
      }
    ]
  },
  "report": {
    "summaryMetrics": [
      "taskBoard"
    ],
    "table": {
      "metricKey": "taskBoard",
      "columns": [
        {
          "key": "title",
          "label": "Scenario"
        },
        {
          "key": "assignedTo",
          "label": "Worker",
          "width": 120
        },
        {
          "key": "status",
          "label": "Status",
          "width": 80
        },
        {
          "key": "result",
          "label": "Result",
          "width": 80
        },
        {
          "key": "retries",
          "label": "Retries",
          "width": 60
        }
      ]
    }
  },
  "configSchema": {
    "plannedScenarios": {
      "type": "integer",
      "min": 1,
      "max": 100,
      "default": 12
    },
    "parallelism": {
      "type": "integer",
      "min": 1,
      "max": 8,
      "default": 2
    },
    "maxRetriesPerScenario": {
      "type": "integer",
      "min": 0,
      "max": 3,
      "default": 2
    },
    "scenarioTimeoutMin": {
      "type": "integer",
      "min": 1,
      "max": 30,
      "default": 10
    },
    "minPassRatePct": {
      "type": "integer",
      "min": 50,
      "max": 100,
      "default": 90
    },
    "runAccessibility": {
      "type": "integer",
      "min": 0,
      "max": 1,
      "default": 1
    },
    "runVisualDiff": {
      "type": "integer",
      "min": 0,
      "max": 1,
      "default": 0
    },
    "visualDiffThresholdPct": {
      "type": "number",
      "min": 0,
      "max": 10,
      "default": 1
    },
    "exhaustFixRetries": {
      "type": "integer",
      "min": 0,
      "max": 1,
      "default": 1
    },
    "maxFixTasksPerCycle": {
      "type": "integer",
      "min": 1,
      "max": 50,
      "default": 20
    }
  },
  "roomConfigSchema": {
    "targetPath": {
      "type": "directory",
      "label": "Pick Directory (Repo)",
      "required": true,
      "placeholder": "Select a repository directory"
    },
    "targetRuntime": {
      "type": "enum",
      "label": "Target Runtime",
      "default": "auto",
      "options": [
        "auto",
        "electron",
        "web"
      ]
    },
    "harnessCommand": {
      "type": "string",
      "label": "Harness Command",
      "placeholder": "e.g. npm run test:uiux"
    },
    "testPersonas": {
      "type": "string_array",
      "label": "Personas",
      "default": [
        "default"
      ],
      "placeholder": "One persona per line"
    }
  },
  "setup": {
    "compatibilityGate": true,
    "compatibilityTitle": "Compatibility",
    "compatibilityDescription": "Run compatibility checks before creating the room.",
    "checkLabel": "Check Compatibility",
    "fixLabel": "Make Compatible",
    "allowMakeCompatible": true
  }
}
